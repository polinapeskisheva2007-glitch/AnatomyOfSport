<Window x:Class="AnatomyOfSport.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История тренировок" 
        Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="LayoutTransform.ScaleX" 
                                                 To="1.05" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="LayoutTransform.ScaleY" 
                                                 To="1.05" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="LayoutTransform.ScaleX" 
                                                 To="1" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="LayoutTransform.ScaleY" 
                                                 To="1" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя полоска -->
        <Border Grid.Row="0" Background="#235347">
            <Grid>
                <TextBlock Text="История тренировок" 
                           FontFamily="Comic Sans MS"
                           FontSize="16" FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">
                    <Button x:Name="MinimizeButton" Content="─" Width="30" Height="30"
                            Background="Transparent" Foreground="White" FontSize="16"
                            Cursor="Hand" BorderThickness="0"/>
                    <Button x:Name="CloseButton" Content="✕" Width="30" Height="30"
                            Background="Transparent" Foreground="White" FontSize="16"
                            Cursor="Hand" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной фон -->
        <Grid Grid.Row="1">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#479783" Offset="0"/>
                    <GradientStop Color="#FFF5F5DC" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Кнопка НАЗАД -->
            <Button x:Name="BackButton"
                    Content="← НАЗАД"
                    Width="100" Height="30"
                    FontFamily="Comic Sans MS" FontSize="14"
                    Background="#235347" Foreground="#FFF5F5DC"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="20,20,0,0" Cursor="Hand"/>

            <!-- Кнопка ПОМОЩЬ -->
            <Button x:Name="HelpButton"
                    Content="ПОМОЩЬ"
                    Width="100" Height="30"
                    FontFamily="Comic Sans MS" FontSize="14"
                    Background="#235347" Foreground="#FFF5F5DC"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,20,20,0" Cursor="Hand"/>

            <!-- Заголовок -->
            <TextBlock Text="📋 ИСТОРИЯ ТРЕНИРОВОК"
                       FontFamily="Comic Sans MS"
                       FontSize="36" FontWeight="Bold"
                       Foreground="#FFF5F5DC"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="0,50,0,0"/>

            <!-- Список тренировок через ItemsControl -->
            <ScrollViewer VerticalAlignment="Top"
                          Margin="50,120,50,0" Height="320"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="HistoryList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#235347"
                                    CornerRadius="15"
                                    Padding="20"
                                    Margin="0,0,0,15"
                                    Width="700">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Дата -->
                                    <TextBlock Grid.Row="0"
                                               Text="{Binding Date}"
                                               FontFamily="Comic Sans MS"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,0,0,5"/>

                                    <!-- Время тренировки -->
                                    <TextBlock Grid.Row="1"
                                           FontFamily="Comic Sans MS"
                                           FontSize="14" Foreground="#FFF5F5DC"
                                           Margin="0,0,0,10">
                                    <Run Text="⏱️ Время: "/>
                                    <Run Text="{Binding FormattedDuration, Mode=OneWay}"/>
                                    </TextBlock>

                                    <!-- Список упражнений -->
                                    <ItemsControl Grid.Row="2"
                                                  ItemsSource="{Binding Exercises}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock FontFamily="Comic Sans MS"
                                                           FontSize="14"
                                                           Foreground="#FFF5F5DC">
                                                    <Run Text="• "/>
                                                    <Run Text="{Binding ExerciseName, Mode=OneWay}"/>
                                                    <Run Text=" — "/>
                                                    <Run Text="{Binding Sets, Mode=OneWay}"/>
                                                    <Run Text="×"/>
                                                    <Run Text="{Binding Reps, Mode=OneWay}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Нижние кнопки -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,20">
                <Button x:Name="HomeButton" Content="ГЛАВНАЯ"
                        FontFamily="Comic Sans MS" Width="120" Height="35"
                        FontSize="14" Background="#235347" Foreground="#FFF5F5DC"
                        Cursor="Hand" Margin="0,0,100,0"/>
                <Button x:Name="LibraryButton" Content="БИБЛИОТЕКА"
                        FontFamily="Comic Sans MS" Width="120" Height="35"
                        FontSize="14" Background="#235347" Foreground="#FFF5F5DC"
                        Cursor="Hand" Margin="0,0,100,0"/>
                <Button x:Name="MyWorkoutButton" Content="СВОЯ ТРЕНИРОВКА"
                        FontFamily="Comic Sans MS" Width="146" Height="35"
                        FontSize="14" Background="#235347" Foreground="#FFF5F5DC"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>