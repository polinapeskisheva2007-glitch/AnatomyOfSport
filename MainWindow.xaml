<Window x:Class="AnatomyOfSport.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анатомия спорта" 
        Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Normal">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="LayoutTransform.ScaleX" 
                                                 To="1.05" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="LayoutTransform.ScaleY" 
                                                 To="1.05" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="LayoutTransform.ScaleX" 
                                                 To="1" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="LayoutTransform.ScaleY" 
                                                 To="1" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя полоска -->
        <Border Grid.Row="0" Background="#235347">
            <Grid>
                <TextBlock Text="Анатомия спорта" 
                           FontFamily="Comic Sans MS"
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">
                    <Button x:Name="MinimizeButton" Content="─" Width="30" Height="30"
                            Background="Transparent" Foreground="White" FontSize="16"
                            Cursor="Hand" BorderThickness="0"/>
                    <Button x:Name="CloseButton" Content="✕" Width="30" Height="30"
                            Background="Transparent" Foreground="White" FontSize="16"
                            Cursor="Hand" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной фон -->
        <Grid Grid.Row="1">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#479783" Offset="0"/>
                    <GradientStop Color="#FFF5F5DC" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Кнопка ПОМОЩЬ — правый верхний угол -->
            <Button x:Name="HelpButton"
                    Content="ПОМОЩЬ"
                    Width="100" Height="30"
                    FontFamily="Comic Sans MS"
                    FontSize="14"
                    Background="#235347"
                    Foreground="#FFF5F5DC"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,20,20,0"
                    Cursor="Hand"/>

            <!-- Внутренняя сетка -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <TextBlock Grid.Row="1"
                           Text="АНАТОМИЯ СПОРТА"
                           FontFamily="Comic Sans MS"
                           FontSize="40" 
                           FontWeight="Bold" 
                           Foreground="#FFF5F5DC"
                           HorizontalAlignment="Center" 
                           Margin="0,20,0,20"/>

                <!-- Быстрый старт -->
                <Button x:Name="QuickStartButton"
                        Grid.Row="2"
                        Content="⚡ БЫСТРЫЙ СТАРТ"
                        FontFamily="Comic Sans MS"
                        Width="380" Height="83"
                        FontSize="30" 
                        Background="#32AD2B"
                        Foreground="#FFF5F5DC"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                        Margin="0,40,0,15"/>

                <!-- Поиск упражнений -->
                <Button x:Name="SearchButton"
                        Grid.Row="1"
                        Content="🔍 ПОИСК УПРАЖНЕНИЙ"
                        Width="328" Height="49"
                        FontFamily="Comic Sans MS"
                        FontSize="19"
                        Background="#235347"
                        Foreground="#FFF5F5DC"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                        Margin="0,81,0,115" Grid.RowSpan="2"/>

                <!-- Кнопки групп мышц -->
                <Grid Grid.Row="3" Margin="50,20,50,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button x:Name="ChestButton" Grid.Row="0" Grid.Column="0"
                            Content="ГРУДЬ" Width="123" Height="30"
                            FontSize="14" Background="#235347" 
                            Foreground="#FFF5F5DC" Cursor="Hand"
                            HorizontalAlignment="Center" Margin="5"/>
                    <Button x:Name="BackButton" Grid.Row="0" Grid.Column="1"
                            Content="СПИНА" Width="123" Height="30"
                            FontSize="14" Background="#235347" 
                            Foreground="#FFF5F5DC" Cursor="Hand"
                            HorizontalAlignment="Center" Margin="0,5,0,5"/>
                    <Button x:Name="ShouldersButton" Grid.Row="0" Grid.Column="2"
                            Content="РУКИ" Width="123" Height="30"
                            FontSize="14" Background="#235347" 
                            Foreground="#FFF5F5DC" Cursor="Hand"
                            HorizontalAlignment="Center" Margin="5"/>
                    <Button x:Name="LegsButton" Grid.Row="1" Grid.Column="0"
                            Content="НОГИ" Width="123" Height="30"
                            FontSize="14" Background="#235347" 
                            Foreground="#FFF5F5DC" Cursor="Hand"
                            HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <Button x:Name="AbsButton" Grid.Row="1" Grid.Column="1"
                            Content="ПРЕСС" Width="123" Height="30"
                            FontSize="14" Background="#235347" 
                            Foreground="#FFF5F5DC" Cursor="Hand"
                            HorizontalAlignment="Center" Margin="5"/>
                    <Button x:Name="GlutesButton" Grid.Row="1" Grid.Column="2"
                            Content="ЯГОДИЦЫ" Width="123" Height="30"
                            FontSize="14" Background="#235347" 
                            Foreground="#FFF5F5DC" Cursor="Hand"
                            HorizontalAlignment="Center" Margin="5"/>
                </Grid>

                <!-- Нижние кнопки -->
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal" 
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top" Width="622" Margin="111,210,0,0">
                    <Button x:Name="HistoryButton"
                            Content="ИСТОРИЯ"
                            FontFamily="Comic Sans MS"
                            Width="127" Height="35"
                            FontSize="14"
                            Background="#235347"
                            Foreground="#FFF5F5DC"
                            Cursor="Hand"
                            Margin="0,0,100,0"/>
                    <Button x:Name="LibraryButton"
                            Content="БИБЛИОТЕКА"
                            FontFamily="Comic Sans MS"
                            Width="127" Height="35"
                            FontSize="14"
                            Background="#235347"
                            Foreground="#FFF5F5DC"
                            Cursor="Hand"
                            Margin="0,0,100,0"/>
                    <Button x:Name="MyWorkoutButton"
                            Content="СВОЯ ТРЕНИРОВКА"
                            FontFamily="Comic Sans MS"
                            Width="146" Height="35"
                            FontSize="14"
                            Background="#235347"
                            Foreground="#FFF5F5DC"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>